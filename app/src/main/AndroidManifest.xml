<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Core flow needs no permissions. Root needs no manifest permission (uses `su` if present).
         Overlay tier: SYSTEM_ALERT_WINDOW is a special permission the user grants at runtime via
         "Display over other apps" (Settings.canDrawOverlays / ACTION_MANAGE_OVERLAY_PERMISSION). -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:name=".ApnApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ApnSettingsHelper">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ApnSettingsHelper">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Invisible one-shot clipboard writer (overlay's foreground-write fallback). Own empty task
             affinity + excludeFromRecents/noHistory so it never surfaces UI or lingers in recents. -->
        <activity
            android:name=".ui.overlay.ClipboardWriteActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@style/Theme.ApnSettingsHelper.Invisible" />
    </application>
</manifest>
